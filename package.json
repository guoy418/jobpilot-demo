{
  "name": "jobpilot-local",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:local": "node tools/local_dev.cjs",
    "dev:local:check": "node tools/local_dev.cjs --smoke",
    "dev": "vite --host 0.0.0.0",
    "dev:demo": "vite --host 0.0.0.0 --mode demo",
    "build": "tsc -b && vite build",
    "build:demo": "tsc -b && vite build --mode demo",
    "demo:check": "npm run build:demo && node tools/demo_safety_check.cjs",
    "preview": "vite preview --host 0.0.0.0",
    "preview:demo": "vite preview --host 0.0.0.0 --mode demo",
    "api": "node server/index.mjs",
    "api:check": "node server/check.mjs",
    "api:check:persistence": "node server/persistence-check.mjs",
    "mvp:check": "node tools/mvp_check.cjs",
    "audit:v07": "node tools/v07_webapp_audit.cjs",
    "audit:v07.2": "node tools/v07_2_acceptance_audit.cjs",
    "audit": "npm run audit:v07 && npm run audit:v07.2",
    "test": "vitest run",
    "test:api-persistence": "node server/persistence-check.mjs",
    "test:e2e:local": "node tools/local_e2e.cjs",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "playwright-core": "^1.60.0",
    "vitest": "^4.1.9"
  }
}
